# Baked into the static bundle at export time. All PUBLIC — safe to ship.
# NEVER add SUPABASE_SERVICE_ROLE_KEY or any secret here (the ESLint guardrail
# also blocks importing server-only modules into the bundle).

NEXT_PUBLIC_API_BASE=https://www.ghdidi.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
