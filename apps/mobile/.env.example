# Baked into the static bundle at export time. All PUBLIC — safe to ship.
# NEVER add SUPABASE_SERVICE_ROLE_KEY or any secret here (the ESLint guardrail
# also blocks importing server-only modules into the bundle).

NEXT_PUBLIC_API_BASE=https://ghdidi.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── Phase 2 native config (NOT in the JS bundle) ──
# Push (FCM/APNs) — set on apps/web (server), not here:
#   FCM_PROJECT_ID, FCM_CLIENT_EMAIL, FCM_PRIVATE_KEY  (service account)
# Android: place google-services.json in android/app/ after `cap add android`
# iOS: enable Push capability + upload APNs key in Apple Developer + Firebase
# Deep links: fill the placeholders in
#   apps/web/public/.well-known/assetlinks.json (Android SHA256 fingerprint)
#   apps/web/public/.well-known/apple-app-site-association (Apple Team ID)
