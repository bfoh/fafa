# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ExpressPay (Ghana) — current payment provider
EXPRESSPAY_MERCHANT_ID=your_expresspay_merchant_id
EXPRESSPAY_API_KEY=your_expresspay_api_key
EXPRESSPAY_ENV=sandbox   # sandbox | production

# Paystack (Ghana) — legacy; subaccount/bank settings UI still references it
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxx
PAYSTACK_SECRET_KEY=sk_test_xxxx

# Arkesel (SMS)
ARKESEL_API_KEY=your_arkesel_api_key

# Brevio (Email)
BREVIO_API_KEY=your_brevio_api_key

# App
NEXT_PUBLIC_URL=http://localhost:3000
